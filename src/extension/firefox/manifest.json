{
	"manifest_version": 3,
	"name": "Discord Music Status",
	"description": "Shows what's playing as Discord status",
	"version": "1.3.1",
	"icons": {
		"128": "logo_128.png"
	},
	"host_permissions": ["http://localhost/*"],
	"content_scripts": [{
		"matches": ["<all_urls>"],
		"js": ["content.js"],
		"run_at": "document_idle"
	}],
	"homepage_url": "https://github.com/SuperZombi/Discord-Music-Status",
	"browser_specific_settings": {
		"gecko": {
			"id": "super.zombi@discord.music.status",
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	}
}
